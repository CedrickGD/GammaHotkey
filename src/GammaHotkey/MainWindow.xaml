<Window x:Class="GammaHotkey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:GammaHotkey.Controls"
        xmlns:conv="clr-namespace:GammaHotkey.Mvvm"
        xmlns:vm="clr-namespace:GammaHotkey.ViewModels"
        Title="GammaHotkey" Height="680" Width="900"
        MinHeight="580" MinWidth="740"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgWindow}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextElement.Foreground="{StaticResource TextPrimary}"
        FontFamily="{StaticResource AppFont}"
        Icon="pack://application:,,,/Assets/app.ico"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>
        <conv:ZeroCountToVisibilityConverter x:Key="ZeroCount"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================================================= HEADER -->
        <Border Grid.Row="0" Padding="24,16" Background="{StaticResource BgWindow}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="9" Background="{StaticResource Accent}">
                        <Grid Width="22" Height="22">
                            <Ellipse Width="9" Height="9" Fill="{StaticResource OnAccent}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Path Stroke="{StaticResource OnAccent}" StrokeThickness="1.9"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M11,1 V3.4 M11,18.6 V21 M1,11 H3.4 M18.6,11 H21 M3.9,3.9 L5.6,5.6 M16.4,16.4 L18.1,18.1 M18.1,3.9 L16.4,5.6 M5.6,16.4 L3.9,18.1"/>
                        </Grid>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="GammaHotkey" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Gamma hotkeys for G HUB" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextDisabled}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListening}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Success}"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="DotPulse">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     To="1.7" Duration="0:0:0.9"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     To="1.7" Duration="0:0:0.9"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="DotPulse"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ListeningLabel}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListening}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <CheckBox Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                              IsChecked="{Binding IsListening}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================================================= BODY -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,4">
            <StackPanel>

                <!-- GAMMA PRESETS -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="GAMMA PRESETS"/>

                        <ItemsControl ItemsSource="{Binding Presets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,28,14">
                                        <TextBlock Text="{Binding Name}" Width="92" VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <TextBox Style="{StaticResource NumberBox}"
                                                 Text="{Binding Value, StringFormat={}{0:0.00}, UpdateSourceTrigger=LostFocus}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Live preview" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,16,0"/>
                            <Slider Grid.Column="1" Style="{StaticResource PreviewSlider}" VerticalAlignment="Center"
                                    Minimum="0.1" Maximum="2.5"
                                    Value="{Binding PreviewGamma, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="{Binding PreviewGammaText}" Width="48"
                                       TextAlignment="Right" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Content="Apply / Test"
                                    Command="{Binding ApplyPreviewCommand}" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Reset to 1.0"
                                    Command="{Binding ResetCommand}"/>
                        </StackPanel>

                        <TextBlock Style="{StaticResource HelperText}" Margin="0,12,0,0"
                                   Text="Apply changes your screen gamma right now so you can see it. Higher = brighter. Reset restores Windows default (1.0)."/>
                    </StackPanel>
                </Border>

                <!-- TRIGGERS -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="TRIGGERS"/>

                        <!-- Segmented control -->
                        <Border Background="{StaticResource SurfaceInput}" CornerRadius="8" Padding="3"
                                HorizontalAlignment="Left" BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Style="{StaticResource SegmentRadio}" Content="Cycle mode"
                                             GroupName="mode" IsChecked="{Binding IsCycleMode}"/>
                                <RadioButton Style="{StaticResource SegmentRadio}" Content="Direct bindings"
                                             GroupName="mode" IsChecked="{Binding IsDirectMode}"/>
                            </StackPanel>
                        </Border>

                        <!-- Cycle panel -->
                        <StackPanel Margin="0,16,0,0" Visibility="{Binding IsCycleMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </StackPanel.RenderTransform>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCycleMode}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Style="{StaticResource HelperText}"
                                       Text="One key steps through the presets you pick, in order."/>
                            <TextBlock Text="Presets in cycle" Style="{StaticResource FieldLabel}" Margin="0,14,0,8"/>
                            <ItemsControl ItemsSource="{Binding Presets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource ChipToggle}" Content="{Binding Name}"
                                                      IsChecked="{Binding IsInCycle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Advance key" Style="{StaticResource FieldLabel}" Margin="0,8,0,8"/>
                            <ctrl:KeyCapturePill HorizontalAlignment="Left" Trigger="{Binding CycleTrigger, Mode=TwoWay}"/>
                            <TextBlock Style="{StaticResource HelperText}" Margin="0,10,0,0"
                                       Text="Each press jumps to the next preset, then wraps back to the first. Tip: pick an F13–F24 key (the ▾ menu) and have G HUB send it from a mouse button."/>
                        </StackPanel>

                        <!-- Direct panel -->
                        <StackPanel Margin="0,16,0,0" Visibility="{Binding IsDirectMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </StackPanel.RenderTransform>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDirectMode}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Style="{StaticResource HelperText}"
                                       Text="Bind one key to one preset. Press it to jump straight there."/>

                            <TextBlock Style="{StaticResource HelperText}" Margin="0,12,0,0"
                                       Visibility="{Binding DirectBindings.Count, Converter={StaticResource ZeroCount}}"
                                       Text="No bindings yet. Add one to map a key to a preset."/>

                            <ItemsControl ItemsSource="{Binding DirectBindings}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="210"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*" MinWidth="150"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ctrl:KeyCapturePill Grid.Column="0" Trigger="{Binding Trigger, Mode=TwoWay}"/>
                                            <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="16" Margin="12,0"
                                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                            <ComboBox Grid.Column="2" Style="{StaticResource ThemedCombo}"
                                                      ItemsSource="{Binding DataContext.LevelOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedValuePath="Level" DisplayMemberPath="Name"
                                                      SelectedValue="{Binding SelectedLevel}"/>
                                            <Button Grid.Column="3" Style="{StaticResource IconGhostButton}" Content="&#x2715;"
                                                    Margin="6,0,0,0" ToolTip="Remove"
                                                    Command="{Binding DataContext.RemoveBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Style="{StaticResource GhostButton}" Content="+ Add binding"
                                    HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Command="{Binding AddBindingCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- G HUB EXPORT -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="G HUB EXPORT"/>

                        <Grid>
                            <Button Style="{StaticResource PrimaryButton}" Content="Generate Lua script"
                                    HorizontalAlignment="Left" Command="{Binding GenerateLuaCommand}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource IconButton}" ToolTip="Copy to clipboard"
                                        Command="{Binding CopyLuaCommand}" Margin="0,0,8,0">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource CopyGeometry}"/>
                                </Button>
                                <Button Style="{StaticResource IconButton}" ToolTip="Save as .lua"
                                        Command="{Binding SaveLuaCommand}" Margin="0,0,8,0">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource SaveGeometry}"/>
                                </Button>
                                <Button Style="{StaticResource IconButton}" ToolTip="Open in a larger window"
                                        Click="ExpandScript_Click">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource ExpandGeometry}"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Margin="0,14,0,0" CornerRadius="8" Background="{StaticResource SurfaceInput}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1" MinHeight="130" MaxHeight="320">
                            <TextBox Text="{Binding LuaScript, Mode=OneWay}" IsReadOnly="True"
                                     Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12.5" Padding="12"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" AcceptsReturn="True"/>
                        </Border>

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Style="{StaticResource HelperText}" Text="1. In G HUB, open your profile → Assignments → Scripting."/>
                            <TextBlock Style="{StaticResource HelperText}" Margin="0,4,0,0" Text="2. Paste this script (or open the saved .lua), then save."/>
                            <TextBlock Style="{StaticResource HelperText}" Margin="0,4,0,0" Text="3. Keep GammaHotkey running with Listening turned on."/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ================================================= FOOTER -->
        <Border Grid.Row="2" Padding="24,12" Background="{StaticResource BgWindow}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Style="{StaticResource ThemedCheck}" Content="Run on startup"
                              IsChecked="{Binding RunOnStartup}"/>

                    <Button x:Name="MonitorsButton" Style="{StaticResource SecondaryButton}" Margin="16,0,0,0"
                            Click="MonitorsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16" Margin="0,0,8,0"
                                  Data="{StaticResource MonitorGeometry}"/>
                            <TextBlock Text="{Binding MonitorsSummary}" VerticalAlignment="Center"/>
                            <TextBlock Text="&#x25B4;" Margin="8,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Popup x:Name="MonitorsPopup" PlacementTarget="{Binding ElementName=MonitorsButton}"
                           Placement="Top" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="-6">
                        <Border Background="{StaticResource SurfaceElevated}" BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="10" Padding="12" Effect="{StaticResource CardShadow}" MinWidth="290">
                            <StackPanel>
                                <TextBlock Text="APPLY GAMMA TO" Style="{StaticResource SectionHeader}" Margin="2,0,0,10"/>
                                <CheckBox Style="{StaticResource ThemedCheck}" Content="All monitors"
                                          IsChecked="{Binding AllMonitors}" Margin="2,0,2,8"/>
                                <Border Height="1" Background="{StaticResource Border}" Margin="0,2,0,8"/>
                                <ItemsControl ItemsSource="{Binding Monitors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource ThemedCheck}" Margin="2,5" Content="{Binding Display}"
                                                      IsChecked="{Binding IsSelected}"
                                                      IsEnabled="{Binding DataContext.IndividualMonitorsEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"
                           Margin="16,0,0,0" TextTrimming="CharacterEllipsis"
                           Text="{Binding Status}" ToolTip="{Binding Status}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusIsSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusIsWarning}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
